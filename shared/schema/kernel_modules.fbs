namespace Anticheat;

table SectionInfo {
    name: string;
    virtual_address: uint32;
    virtual_size: uint32;
    characteristics: uint32;
}

table KernelModule {
    base_address: uint64;
    size: uint32;
    name: string;
    hash: [ubyte];
    full_path: string;
    rwx_section: string;
    sections: [SectionInfo];
}

table KernelModuleList {
    modules: [KernelModule];
}
